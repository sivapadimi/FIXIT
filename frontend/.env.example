# API Configuration
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_SOCKET_URL=http://localhost:5000

# Event Configuration
REACT_APP_EVENT_NAME=FixIt 2024
REACT_APP_EVENT_DESCRIPTION=Annual Debugging Competition

# UI Configuration
REACT_APP_THEME=dark
REACT_APP_PRIMARY_COLOR=blue
REACT_APP_SHOW_DEBUG=false

# Feature Flags
REACT_APP_ENABLE_LEADERBOARD=true
REACT_APP_ENABLE_REAL_TIME_UPDATES=true
REACT_APP_ENABLE_CODE_EXECUTION=true
REACT_APP_ENABLE_TIME_COMPLEXITY=true

# Performance
REACT_APP_MAX_CODE_SIZE=10000
REACT_APP_EXECUTION_TIMEOUT=30000
REACT_APP_SUBMISSION_RATE_LIMIT=5
